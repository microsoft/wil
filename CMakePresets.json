{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 29,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-msvc-base",
            "description": "Base build for Windows MSVC",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/build/install/${presetName}",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Release;Debug;RelWithDebInfo;MinSizeRel"
            }
        },
        {
            "name": "windows-clang-base",
            "description": "Base build for Windows Clang",
            "hidden": true,
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/build/install/${presetName}",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_CONFIGURATION_TYPES": "Release;Debug;RelWithDebInfo;MinSizeRel",
                "CMAKE_C_COMPILER": "clang-cl",
                "CMAKE_CXX_COMPILER": "clang-cl"
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "intelliSenseMode": "windows-clang-x64"
                }
            }
        },
        {
            "name": "x64-msvc",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "inherits": "windows-msvc-base"
        },
        {
            "name": "x86-msvc",
            "architecture": {
                "value": "x86",
                "strategy": "external"
            },
            "inherits": "windows-msvc-base"
        },
        {
            "name": "arm64-msvc",
            "architecture": {
                "value": "arm64",
                "strategy": "external"
            },
            "inherits": "windows-msvc-base"
        },
        {
            "name": "x64-clang",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "inherits": "windows-clang-base"
        },
        {
            "name": "x86-clang",
            "architecture": {
                "value": "x86",
                "strategy": "external"
            },
            "inherits": "windows-clang-base"
        },
        {
            "name": "arm64-clang",
            "architecture": {
                "value": "arm64",
                "strategy": "external"
            },
            "inherits": "windows-clang-base"
        }
    ],
    "buildPresets": [
        { "name": "x64-clang-debug", "configurePreset": "x64-clang", "configuration": "Debug" },
        { "name": "x64-clang-relwithdebinfo", "configurePreset": "x64-clang", "configuration": "RelWithDebInfo" },
        { "name": "x64-clang-release", "configurePreset": "x64-clang", "configuration": "Release" },
        { "name": "x64-clang-minsizerel", "configurePreset": "x64-clang", "configuration": "MinSizeRel" },
        { "name": "x86-clang-debug", "configurePreset": "x86-clang", "configuration": "Debug" },
        { "name": "x86-clang-relwithdebinfo", "configurePreset": "x86-clang", "configuration": "RelWithDebInfo" },
        { "name": "x86-clang-release", "configurePreset": "x86-clang", "configuration": "Release" },
        { "name": "x86-clang-minsizerel", "configurePreset": "x86-clang", "configuration": "MinSizeRel" },
        { "name": "arm64-clang-debug", "configurePreset": "arm64-clang", "configuration": "Debug" },
        { "name": "arm64-clang-relwithdebinfo", "configurePreset": "arm64-clang", "configuration": "RelWithDebInfo" },
        { "name": "arm64-clang-release", "configurePreset": "arm64-clang", "configuration": "Release" },
        { "name": "arm64-clang-minsizerel", "configurePreset": "arm64-clang", "configuration": "MinSizeRel" },
        { "name": "x64-msvc-debug", "configurePreset": "x64-msvc", "configuration": "Debug" },
        { "name": "x64-msvc-relwithdebinfo", "configurePreset": "x64-msvc", "configuration": "RelWithDebInfo" },
        { "name": "x64-msvc-release", "configurePreset": "x64-msvc", "configuration": "Release" },
        { "name": "x64-msvc-minsizerel", "configurePreset": "x64-msvc", "configuration": "MinSizeRel" },
        { "name": "x86-msvc-debug", "configurePreset": "x86-msvc", "configuration": "Debug" },
        { "name": "x86-msvc-relwithdebinfo", "configurePreset": "x86-msvc", "configuration": "RelWithDebInfo" },
        { "name": "x86-msvc-release", "configurePreset": "x86-msvc", "configuration": "Release" },
        { "name": "x86-msvc-minsizerel", "configurePreset": "x86-msvc", "configuration": "MinSizeRel" },
        { "name": "arm64-msvc-debug", 	"configurePreset": 	"arm64-msvc", "configuration": "Debug" },
        { "name": "arm64-msvc-relwithdebinfo", "configurePreset": "arm64-msvc", "configuration": "RelWithDebInfo" },
        { "name": "arm64-msvc-release", "configurePreset": "arm64-msvc", "configuration": "Release" },
        { "name": "arm64-msvc-minsizerel", "configurePreset": "arm64-msvc", "configuration": "MinSizeRel" }
    ]
}